# Kopieer dit bestand naar ".env" (staat in .gitignore, wordt dus nooit gecommit) en vul
# de echte waarden in. Ontbreekt .env, dan gelden de Laragon-defaults in config/config.php.
#
# Dit ene bestand bevat BEIDE omgevingsprofielen (LOCAL_* en HOSTNET_*) — hetzelfde bestand
# staat zowel lokaal als (na SFTP-upload als ".env") op de live Hostnet-server. APP_ENV bepaalt
# welk blok geldt; dat is de enige regel die je bewust handmatig anders zet per omgeving.
#
# Nieuwe sleutels toevoegen? Voeg ze hier toe (zonder echte waarde) en draai daarna
# "Rebuild .env" in scripts/dev-tools.ps1 — dat vult ontbrekende sleutels aan in je bestaande
# .env zonder bestaande waarden te overschrijven.
#
# APP_ENV bepaalt niet alleen welk DB_*/MAIL_*/APP_URL-blok hieronder geldt, maar ook (afgeleid,
# zie config/config.php) of dev-gedrag aanstaat: alles behalve "hostnet" telt als ontwikkelomgeving
# (auto git pull + schema-sync op /login, PHP-fouten zichtbaar). Voor "hostnet" staat dat altijd
# uit — geen losse *_APP_DEV/*_APP_GIT_PULL_ENABLED/*_APP_DEBUG-sleutels meer nodig per omgeving.
APP_ENV=local

# --- Lokaal ---
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=3306
LOCAL_DB_DATABASE=leenvanpunt
LOCAL_DB_USERNAME=root
LOCAL_DB_PASSWORD=

# Basis-URL van de applicatie, gebruikt om absolute links te bouwen in e-mails.
LOCAL_APP_URL=http://localhost:8000

# Leeg laten = er wordt niets verstuurd (Mailer gooit een RuntimeException, EmailQueueProcessor
# vangt dit op en zet de mail op status 'error') — veilige default lokaal, zodat je niet per
# ongeluk echte medewerkers mailt tijdens het testen.
LOCAL_MAIL_HOST=
LOCAL_MAIL_PORT=587
LOCAL_MAIL_ENCRYPTION=tls
LOCAL_MAIL_USERNAME=
LOCAL_MAIL_PASSWORD=
LOCAL_MAIL_FROM_ADDRESS=noreply@bergthaler.dev
LOCAL_MAIL_FROM_NAME="Ticketsysteem Leen van Punt"
LOCAL_MAIL_ADMIN_ADDRESS=

# --- Hostnet (of een andere live/productie-omgeving) ---
HOSTNET_DB_HOST=mysql.xxxxxxxx.service.one
HOSTNET_DB_PORT=3306
HOSTNET_DB_DATABASE=xxxxxxxx_leenvanpunt
HOSTNET_DB_USERNAME=xxxxxxxx_gebruiker
HOSTNET_DB_PASSWORD=

HOSTNET_APP_URL=https://bergthaler.dev

HOSTNET_MAIL_HOST=
HOSTNET_MAIL_PORT=587
HOSTNET_MAIL_ENCRYPTION=tls
HOSTNET_MAIL_USERNAME=
HOSTNET_MAIL_PASSWORD=
HOSTNET_MAIL_FROM_ADDRESS=noreply@bergthaler.dev
HOSTNET_MAIL_FROM_NAME="Ticketsysteem Leen van Punt"
HOSTNET_MAIL_ADMIN_ADDRESS=

# --- Gedeeld tussen omgevingen (niet geprefixt) ---

# Sleutel voor het versleutelen van gevoelige ticketvelden (omschrijving, opdrachtgever_naam) —
# zie App\Shared\Crypto\FieldEncryptor. Base64-encoded, 32 bytes. Genereren met:
# openssl rand -base64 32
# Gebruik dezelfde sleutel op elke omgeving die dezelfde database (kan) delen — bv. na het
# lokaal ophalen van een live dump — anders zijn bestaande versleutelde tickets onleesbaar.
APP_ENCRYPTION_KEY=

# Aantal dagen dat logregels (paginabezoeken, login-pogingen) bewaard blijven voordat het
# opschoon-endpoint (/api/logs/opschonen, scope 'log_opschonen') ze verwijdert.
LOG_RETENTIE_DAGEN=90

# Alleen lokaal nodig, voor scripts/dev-tools.ps1 > "Live database ophalen". Wijst naar het
# /api/database/export-endpoint op de live server en de bijbehorende API-sleutel (aanmaken via
# Beheer > API-sleutels op die server, met scope 'database_export'). Laat leeg op de live server
# zelf — dit endpoint is alleen bedoeld om vanaf je lokale omgeving aangeroepen te worden.
LIVE_DB_EXPORT_URL=
LIVE_DB_EXPORT_KEY=

# Demo-/adminaccount aangemaakt door "php database/seed.php". Leeg laten = de defaults in
# database/seed.php.
SEED_USER_NAAM=
SEED_USER_EMAIL=
SEED_USER_WACHTWOORD=
SEED_USER_ROL=admin

# E-mail & kennisbank verwerking (App\Modules\EmailVerwerking\Services\AiAnalysisService) draait via
# een eigen n8n-webhook i.p.v. een directe AI-provider-call. Leeg laten = analyse slaat over met een
# duidelijke fout in processing_logs (zelfde fail-safe-patroon als LOCAL_MAIL_HOST leeg laten bij de Mailer).
N8N_WEBHOOK_URL=
N8N_API_KEY=
AI_CONFIDENCE_DREMPEL=0.75
