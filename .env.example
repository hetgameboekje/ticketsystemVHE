# Kopieer dit bestand naar ".env" (staat in .gitignore, wordt dus nooit gecommit) en vul
# de echte waarden in voor deze omgeving. Ontbreekt .env, dan gelden de Laragon-defaults
# in config/config.php.
#
# Nieuwe sleutels toevoegen? Voeg ze hier toe (zonder echte waarde) en draai daarna
# "Rebuild .env" in scripts/dev-tools.ps1 — dat vult ontbrekende sleutels aan in je bestaande
# .env zonder bestaande waarden te overschrijven.

# Lokaal
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vhe
DB_USERNAME=root
DB_PASSWORD=

# Hostnet
# DB_HOST=mysql.c9lkxmp0f.service.one
# DB_PORT=3306
# DB_DATABASE=c9lkxmp0f_vhe
# DB_USERNAME=c9lkxmp0f_timo
# DB_PASSWORD=

# true  = lokale ontwikkelomgeving: bij het laden van /login wordt automatisch
#         "git pull" gedaan en het databaseschema geparsed + toegepast.
# false = productie (bv. Hostnet): dit gebeurt alleen nog handmatig via Beheer.
APP_DEV=true

# true  = server heeft shell/exec-toegang (Docker/VPS) — git pull-knop en dev-sync werken.
# false = server heeft GEEN shell-toegang (bv. Hostnet shared webhosting zonder SSH) —
#         schakelt de git pull-knop en het git-onderdeel van dev-sync uit. Database parsen
#         blijft wel werken, want dat gebruikt alleen PDO, geen shell.
APP_GIT_PULL_ENABLED=true

APP_DEBUG=true

# Sleutel voor het versleutelen van gevoelige ticketvelden (omschrijving, opdrachtgever_naam) —
# zie App\Shared\Crypto\FieldEncryptor. Base64-encoded, 32 bytes. Genereren met:
# openssl rand -base64 32
# Gebruik dezelfde sleutel op elke omgeving die dezelfde database gebruikt.
APP_ENCRYPTION_KEY=

# SMTP-instellingen voor uitgaande e-mail (ticketherinneringen/escalaties, zie App\Core\Mailer).
# Leeg laten = er wordt niets verstuurd (Mailer gooit een RuntimeException, EmailQueueProcessor
# vangt dit op en zet de mail op status 'error').
MAIL_HOST=
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@vhe.nl
MAIL_FROM_NAME="Ticketsysteem VHE"
# E-mailadres dat een directe waarschuwing krijgt als de wachtrij >10 openstaande e-mails bevat.
MAIL_ADMIN_ADDRESS=

# Aantal dagen dat logregels (paginabezoeken, login-pogingen) bewaard blijven voordat het
# opschoon-endpoint (/api/logs/opschonen, scope 'log_opschonen') ze verwijdert.
LOG_RETENTIE_DAGEN=90

# Alleen lokaal nodig, voor scripts/dev-tools.ps1 > "Live database ophalen". Wijst naar het
# /api/database/export-endpoint op de live server en de bijbehorende API-sleutel (aanmaken via
# Beheer > API-sleutels op die server, met scope 'database_export'). Laat leeg op de live server
# zelf — dit endpoint is alleen bedoeld om vanaf je lokale omgeving aangeroepen te worden.
LIVE_DB_EXPORT_URL=https://bergthaler.dev/api/database/export
LIVE_DB_EXPORT_KEY=

# Demo-gebruiker aangemaakt door "php database/seed.php". Leeg laten = de defaults hieronder.
SEED_USER_NAAM=Timo Bergthaler
SEED_USER_EMAIL=timo@bergthaler.nl
SEED_USER_WACHTWOORD=demo123
SEED_USER_ROL=admin
