<?xml version="1.0" encoding="UTF-8"?>
<table name="installatie_opdracht_items" engine="InnoDB">
  <columns>
    <column name="id" type="INT" primary="true" auto_increment="true"/>
    <column name="opdracht_id" type="INT" nullable="false" references="installatie_opdrachten.id" on_delete="CASCADE"/>
    <column name="naam" type="VARCHAR" length="150" nullable="false"/>
    <column name="volgorde" type="INT" nullable="false" default="0"/>
    <column name="afgevinkt" type="TINYINT" length="1" nullable="false" default="0"/>
    <column name="afgevinkt_op" type="TIMESTAMP"/>
  </columns>
</table>
