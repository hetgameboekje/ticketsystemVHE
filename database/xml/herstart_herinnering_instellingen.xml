<?xml version="1.0" encoding="UTF-8"?>
<table name="herstart_herinnering_instellingen" engine="InnoDB">
  <columns>
    <column name="id" type="INT" primary="true" auto_increment="true"/>
    <column name="onderwerp" type="VARCHAR" length="255" nullable="false" default="'Even je apparaat herstarten?'"/>
    <column name="inhoud" type="TEXT" nullable="false"/>
    <column name="cc" type="VARCHAR" length="500"/>
    <column name="bcc" type="VARCHAR" length="500"/>
    <column name="updated_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP" on_update="CURRENT_TIMESTAMP"/>
  </columns>
</table>
