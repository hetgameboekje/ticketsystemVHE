<?xml version="1.0" encoding="UTF-8"?>
<table name="ticket_logs" engine="InnoDB">
  <columns>
    <column name="id" type="INT" primary="true" auto_increment="true"/>
    <column name="ticket_id" type="INT" nullable="false" references="tickets.id" on_delete="CASCADE"/>
    <column name="user_id" type="INT" references="users.id"/>
    <column name="opmerking" type="TEXT" nullable="false"/>
    <column name="status_van" type="VARCHAR" length="30"/>
    <column name="status_naar" type="VARCHAR" length="30"/>
    <column name="created_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP"/>
  </columns>
</table>
