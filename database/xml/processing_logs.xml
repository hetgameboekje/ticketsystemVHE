<?xml version="1.0" encoding="UTF-8"?>
<table name="processing_logs" engine="InnoDB">
  <columns>
    <column name="id" type="INT" primary="true" auto_increment="true"/>
    <column name="imported_email_id" type="INT" references="imported_emails.id" on_delete="CASCADE"/>
    <column name="stap" type="VARCHAR" length="30" nullable="false"/>
    <column name="status" type="VARCHAR" length="20" nullable="false"/>
    <column name="bericht" type="TEXT"/>
    <column name="created_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP"/>
  </columns>
</table>
