<?xml version="1.0" encoding="UTF-8"?>
<table name="software_inventaris" engine="InnoDB">
  <columns>
    <column name="id" type="INT" primary="true" auto_increment="true"/>
    <column name="publisher" type="VARCHAR" length="255"/>
    <column name="naam" type="VARCHAR" length="255" nullable="false"/>
    <column name="versie" type="VARCHAR" length="100"/>
    <column name="platform" type="VARCHAR" length="50"/>
    <column name="system_component" type="TINYINT" length="1" nullable="false" default="0"/>
    <column name="eerst_gezien" type="TIMESTAMP"/>
    <column name="laatst_gezien" type="TIMESTAMP"/>
    <column name="aantal_apparaten" type="INT" nullable="false" default="0"/>
    <column name="apparaat_ids" type="TEXT"/>
    <column name="created_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP"/>
  </columns>
</table>
