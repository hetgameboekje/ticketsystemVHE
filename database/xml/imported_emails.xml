<?xml version="1.0" encoding="UTF-8"?>
<table name="imported_emails" engine="InnoDB">
  <columns>
    <column name="id" type="INT" primary="true" auto_increment="true"/>
    <column name="batch_id" type="INT" references="email_import_batches.id"/>
    <column name="bron_message_id" type="VARCHAR" length="255" nullable="false"/>
    <column name="afzender_email" type="VARCHAR" length="255" nullable="false"/>
    <column name="afzender_naam" type="VARCHAR" length="150"/>
    <column name="onderwerp" type="VARCHAR" length="500" nullable="false"/>
    <column name="body_ruw" type="LONGTEXT"/>
    <column name="body_schoon" type="LONGTEXT" nullable="false"/>
    <column name="ontvangen_at" type="TIMESTAMP" nullable="true"/>
    <column name="status" type="VARCHAR" length="20" nullable="false" default="'stored'"/>
    <column name="laatste_fout" type="TEXT"/>
    <column name="created_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP"/>
    <column name="updated_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP" on_update="CURRENT_TIMESTAMP"/>
    <column name="deleted_at" type="TIMESTAMP" nullable="true"/>
  </columns>
</table>
