<?xml version="1.0" encoding="UTF-8"?>
<table name="devices" engine="InnoDB">
  <columns>
    <column name="id" type="INT" primary="true" auto_increment="true"/>
    <column name="naam" type="VARCHAR" length="150" nullable="false"/>
    <column name="extern_apparaat_id" type="VARCHAR" length="50" unique="true"/>
    <column name="medewerker_id" type="INT" references="medewerkers.id" on_delete="SET NULL"/>
    <column name="laatst_geimporteerd_op" type="TIMESTAMP"/>
    <column name="created_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP"/>
    <column name="updated_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP" on_update="CURRENT_TIMESTAMP"/>
    <column name="deleted_at" type="TIMESTAMP"/>
  </columns>
</table>
