<?xml version="1.0" encoding="UTF-8"?>
<table name="installatie_profiel_items" engine="InnoDB">
  <columns>
    <column name="id" type="INT" primary="true" auto_increment="true"/>
    <column name="profiel_id" type="INT" nullable="false" references="installatie_profielen.id" on_delete="CASCADE"/>
    <column name="naam" type="VARCHAR" length="150" nullable="false"/>
    <column name="volgorde" type="INT" nullable="false" default="0"/>
    <column name="created_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP"/>
  </columns>
</table>
