<?xml version="1.0" encoding="UTF-8"?>
<table name="schijfgebruik_schijven" engine="InnoDB">
  <columns>
    <column name="id" type="INT" primary="true" auto_increment="true"/>
    <column name="device_id" type="INT" nullable="false" references="schijfgebruik_devices.id" on_delete="CASCADE"/>
    <column name="letter" type="VARCHAR" length="10" nullable="false"/>
    <column name="disk_type" type="VARCHAR" length="50"/>
    <column name="capaciteit_bytes" type="BIGINT"/>
    <column name="capaciteit_label" type="VARCHAR" length="30"/>
    <column name="gebruik_percentage" type="INT"/>
    <column name="created_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP"/>
  </columns>
</table>
