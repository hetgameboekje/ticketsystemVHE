<?xml version="1.0" encoding="UTF-8"?>
<table name="locatie_gebruikers" engine="InnoDB">
  <columns>
    <column name="id" type="INT" primary="true" auto_increment="true"/>
    <column name="locatie_id" type="INT" nullable="false" references="locaties.id" on_delete="CASCADE"/>
    <column name="user_id" type="INT" nullable="false" references="users.id" on_delete="CASCADE"/>
    <column name="created_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP"/>
  </columns>
</table>
