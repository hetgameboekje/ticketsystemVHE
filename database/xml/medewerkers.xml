<?xml version="1.0" encoding="UTF-8"?>
<table name="medewerkers" engine="InnoDB">
  <columns>
    <column name="id" type="INT" primary="true" auto_increment="true"/>
    <column name="voornaam" type="VARCHAR" length="100" nullable="false"/>
    <column name="achternaam" type="VARCHAR" length="100" nullable="false"/>
    <column name="email" type="VARCHAR" length="150"/>
    <column name="telefoon" type="VARCHAR" length="50"/>
    <column name="functie" type="VARCHAR" length="150"/>
    <column name="afdeling_id" type="INT" references="afdelingen.id"/>
    <column name="startdatum" type="DATE"/>
    <column name="status" type="VARCHAR" length="20" nullable="false" default="'actief'"/>
    <column name="user_id" type="INT" nullable="true" unique="true" references="users.id" on_delete="SET NULL"/>
    <column name="created_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP"/>
    <column name="updated_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP" on_update="CURRENT_TIMESTAMP"/>
    <column name="deleted_at" type="TIMESTAMP"/>
  </columns>
</table>
