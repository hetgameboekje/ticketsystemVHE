<?xml version="1.0" encoding="UTF-8"?>
<table name="login_attempts" engine="InnoDB">
  <columns>
    <column name="id" type="INT" primary="true" auto_increment="true"/>
    <column name="email" type="VARCHAR" length="150" nullable="false"/>
    <column name="user_id" type="INT" references="users.id"/>
    <column name="ip_address" type="VARCHAR" length="45"/>
    <column name="user_agent" type="VARCHAR" length="255"/>
    <column name="success" type="TINYINT" length="1" nullable="false" default="0"/>
    <column name="is_new_ip" type="TINYINT" length="1" nullable="false" default="0"/>
    <column name="created_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP"/>
  </columns>
</table>
