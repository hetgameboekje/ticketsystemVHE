<?xml version="1.0" encoding="UTF-8"?>
<table name="reflectie_logs" engine="InnoDB">
  <columns>
    <column name="id" type="INT" primary="true" auto_increment="true"/>
    <column name="reflectie_id" type="INT" nullable="false" references="reflecties.id" on_delete="CASCADE"/>
    <column name="user_id" type="INT" references="users.id"/>
    <column name="titel" type="VARCHAR" length="255" nullable="false"/>
    <column name="omschrijving" type="TEXT" nullable="false"/>
    <column name="created_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP"/>
  </columns>
</table>
