    <column name="omschrijving" type="VARCHAR" length="255" nullable="false"/>
    <column name="leverancier" type="VARCHAR" length="150"/>
    <column name="bedrag" type="NUMERIC" length="10,2" nullable="false" default="0"/>
    <column name="aankoopdatum" type="DATE"/>
    <column name="afdeling_id" type="INT" references="afdelingen.id"/>
    <column name="aangevraagd_door_id" type="INT" references="users.id"/>
    <column name="status" type="VARCHAR" length="30" nullable="false" default="'aangevraagd'"/>
    <column name="created_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP"/>
    <column name="updated_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP" on_update="CURRENT_TIMESTAMP"/>
  </columns>
</table>
