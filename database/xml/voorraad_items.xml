<?xml version="1.0" encoding="UTF-8"?>
<table name="voorraad_items" engine="InnoDB">
  <columns>
    <column name="id" type="INT" primary="true" auto_increment="true"/>
    <column name="type_id" type="INT" nullable="false"/>
    <column name="variant" type="VARCHAR" length="50"/>
    <column name="serienummer" type="VARCHAR" length="100" unique="true"/>
    <column name="barcode" type="VARCHAR" length="60" nullable="false"/>
    <column name="status" type="VARCHAR" length="20" nullable="false" default="'op_voorraad'"/>
    <column name="locatie" type="VARCHAR" length="150"/>
    <column name="opmerking" type="TEXT"/>
    <column name="aangemaakt_door_id" type="INT"/>
    <column name="created_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP"/>
    <column name="updated_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP" on_update="CURRENT_TIMESTAMP"/>
    <column name="deleted_at" type="TIMESTAMP"/>
  </columns>
</table>
