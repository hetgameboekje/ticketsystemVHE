<?xml version="1.0" encoding="UTF-8"?>
<table name="verbeterpunt_tijdregistraties" engine="InnoDB">
  <columns>
    <column name="id" type="INT" primary="true" auto_increment="true"/>
    <column name="verbeterpunt_id" type="INT" nullable="false" references="verbeterpunten.id" on_delete="CASCADE"/>
    <column name="user_id" type="INT" references="users.id"/>
    <column name="minuten" type="INT" nullable="false"/>
    <column name="created_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP"/>
  </columns>
</table>
