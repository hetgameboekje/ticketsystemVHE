<?xml version="1.0" encoding="UTF-8"?>
<table name="email_attachments" engine="InnoDB">
  <columns>
    <column name="id" type="INT" primary="true" auto_increment="true"/>
    <column name="imported_email_id" type="INT" nullable="false" references="imported_emails.id" on_delete="CASCADE"/>
    <column name="bestandsnaam" type="VARCHAR" length="255" nullable="false"/>
    <column name="pad" type="VARCHAR" length="500" nullable="false"/>
    <column name="mime_type" type="VARCHAR" length="150"/>
    <column name="grootte_bytes" type="INT"/>
    <column name="created_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP"/>
  </columns>
</table>
