<?xml version="1.0" encoding="UTF-8"?>
<table name="urenstaat_registraties" engine="InnoDB">
  <columns>
    <column name="id" type="INT" primary="true" auto_increment="true"/>
    <column name="user_id" type="INT" nullable="false" references="users.id"/>
    <column name="locatie_id" type="INT" references="locaties.id"/>
    <column name="keyuser_id" type="INT" nullable="true" references="medewerkers.id" on_delete="SET NULL"/>
    <column name="datum" type="DATE" nullable="false"/>
    <column name="start_tijd" type="TIME" nullable="false"/>
    <column name="eind_tijd" type="TIME"/>
    <column name="omschrijving" type="VARCHAR" length="255"/>
    <column name="created_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP"/>
    <column name="updated_at" type="TIMESTAMP" nullable="false" default="CURRENT_TIMESTAMP" on_update="CURRENT_TIMESTAMP"/>
    <column name="deleted_at" type="TIMESTAMP"/>
  </columns>
</table>
